#include <Arduino.h>

// 1. Definimos el pin de envío
#define IR_SEND_PIN 9 
#include <IRremote.hpp>

// =====================================================================
// SEÑAL ON (ENCENDIDO) - 200 PULSOS EXACTOS
// Protocolo normalizado para Hyundai/Midea (2 Frames de 100 pulsos)
// =====================================================================
uint16_t signalON[200] = {
    // --- FRAME 1 (100 pulsos) ---
    4400, 4400, // Header
    500, 1650, 500, 550, 500, 1650, 500, 1650, 500, 550, 500, 550, 500, 1650, 500, 550,  // Byte 0
    500, 1650, 500, 550, 500, 1650, 500, 1650, 500, 550, 500, 550, 500, 1650, 500, 550,  // Byte 1
    500, 1650, 500, 1650, 500, 1650, 500, 1650, 500, 1650, 500, 550, 500, 550, 500, 550, // Byte 2
    500, 550, 500, 550, 500, 550, 500, 550, 500, 550, 500, 1650, 500, 1650, 500, 1650,   // Byte 3
    500, 550, 500, 550, 500, 550, 500, 550, 500, 550, 500, 550, 500, 1650, 500, 550,     // Byte 4
    500, 1650, 500, 1650, 500, 1650, 500, 1650, 500, 1650, 500, 1650, 500, 550, 500, 1650,// Byte 5
    500, 5200, // Stop + Gap

    // --- FRAME 2 (Repetición - 100 pulsos) ---
    4400, 4400, // Header
    500, 1650, 500, 550, 500, 1650, 500, 1650, 500, 550, 500, 550, 500, 1650, 500, 550,
    500, 1650, 500, 550, 500, 1650, 500, 1650, 500, 550, 500, 550, 500, 1650, 500, 550,
    500, 1650, 500, 1650, 500, 1650, 500, 1650, 500, 1650, 500, 550, 500, 550, 500, 550,
    500, 550, 500, 550, 500, 550, 500, 550, 500, 550, 500, 1650, 500, 1650, 500, 1650,
    500, 550, 500, 550, 500, 550, 500, 550, 500, 550, 500, 550, 500, 1650, 500, 550,
    500, 1650, 500, 1650, 500, 1650, 500, 1650, 500, 1650, 500, 1650, 500, 550, 500, 1650,
    500
};

void setup() {
    Serial.begin(115200);
    
    // SOLUCIÓN AL ERROR: Pasamos el pin 9 directamente a begin()
    IrSender.begin(IR_SEND_PIN); 
    
    Serial.println(F("--- HYUNDAI AC MASTER CONTROL ---"));
    Serial.println(F("Disparando ON cada 3 segundos..."));
}

void loop() {
    Serial.println(F(">>> ENVIANDO ON (200 PULSOS)..."));
    
    // Enviamos a 38kHz (el estándar de Hyundai)
    IrSender.sendRaw(signalON, 200, 38);
    
    Serial.println(F("Esperando 3 segundos..."));
    delay(3000); 
}
