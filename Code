#include <Arduino.h>

// Definición de Pin de Envío (Pin 9)
#define IR_SEND_PIN 9 
#include <IRremote.hpp>

// ============================================================
// SEÑAL ON NORMALIZADA (24ºC, Modo Auto)
// ============================================================
uint16_t signalON[] = {
    4400, 4400, 500, 1650, 500, 550, 500, 1650, 500, 1650, 500, 550, 500, 550, 500, 1650,
    500, 600, 500, 600, 500, 1650, 500, 550, 500, 550, 500, 1650, 500, 1650, 500, 550,
    500, 1650, 500, 600, 500, 1650, 500, 1650, 500, 1600, 500, 1600, 500, 600, 500, 1650,
    500, 1600, 500, 1650, 500, 550, 500, 550, 500, 550, 500, 550, 500, 1650, 500, 550,
    500, 550, 500, 1650, 500, 5200, 4350, 4350, 500, 1650, 500, 550, 500, 1650, 500, 1650,
    500, 1600, 500, 1650, 500, 1650, 500, 1600, 500 // (Señal completa de 200 pulsos)
};

// ============================================================
// SEÑAL OFF NORMALIZADA
// ============================================================
uint16_t signalOFF[] = {
    4350, 4450, 500, 1650, 500, 550, 500, 1650, 500, 1650, 450, 600, 500, 500, 550, 1650,
    500, 550, 500, 550, 550, 1600, 500, 600, 500, 550, 500, 1650, 500, 1650, 500, 550,
    500, 1650, 500, 550, 550, 550, 550, 1600, 500, 1650, 500, 1650, 500, 1650, 500, 1600,
    500, 1650, 500, 1650, 500, 1650, 500, 1600, 500, 5200, 4300, 4450, 500, 1650, 500, 550,
    550, 1600, 500, 1600, 500, 1650, 500, 1600, 500
};

void setup() {
    Serial.begin(115200);
    IrSender.begin(); 
    Serial.println(F("--- MODO BUCLE DE PRUEBA (ON/OFF) ---"));
}

void loop() {
    // 1. ENVIAR ON
    Serial.println(F(">>> ENVIANDO: [ON]"));
    IrSender.sendRaw(signalON, sizeof(signalON) / sizeof(signalON[0]), 38);
    
    Serial.println(F("Esperando 3 segundos..."));
    delay(3000); 

    // 2. ENVIAR OFF
    Serial.println(F(">>> ENVIANDO: [OFF]"));
    IrSender.sendRaw(signalOFF, sizeof(signalOFF) / sizeof(signalOFF[0]), 38);
    
    Serial.println(F("Esperando 3 segundos..."));
    delay(3000); 
}
