#include <Arduino.h>

const int IR_PIN = 9; // Usamos vuestro Pin 9

// Función para generar la portadora de 38kHz manualmente en el Pin 9
void oscilar(int microsegundos) {
  long pausa = microsegundos / 26; // 26us es el periodo de 38kHz
  for (int i = 0; i < pausa; i++) {
    digitalWrite(IR_PIN, HIGH);
    delayMicroseconds(9); // 9us ON
    digitalWrite(IR_PIN, LOW);
    delayMicroseconds(12); // 12us OFF (ajustado para latencia)
  }
}

void enviarEspacio(int microsegundos) {
  digitalWrite(IR_PIN, LOW);
  delayMicroseconds(microsegundos);
}

void enviarByteHyundai(byte b) {
  for (int i = 0; i < 8; i++) {
    oscilar(560); // Marca
    if (bitRead(b, i)) {
      enviarEspacio(1600); // Uno
    } else {
      enviarEspacio(560);  // Cero
    }
  }
}

void setup() {
  pinMode(IR_PIN, OUTPUT);
  digitalWrite(IR_PIN, LOW);
  Serial.begin(115200);
  Serial.println("MODO MANUAL BIT-BANGING EN PIN 9");
}

void loop() {
  Serial.println("Disparando ráfaga manual...");

  // 1. HEADER
  oscilar(4500);
  enviarEspacio(4400);

  // 2. DATOS (Tus 6 bytes)
  enviarByteHyundai(0xB2);
  enviarByteHyundai(0x4D);
  enviarByteHyundai(0x1F);
  enviarByteHyundai(0xE0);
  enviarByteHyundai(0x20);
  enviarByteHyundai(0xDF);

  // 3. STOP
  oscilar(560);
  enviarEspacio(0);

  Serial.println("Envío completado con éxito.");
  delay(5000); // Espera 5 segundos
}
