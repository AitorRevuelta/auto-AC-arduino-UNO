// PIN 9 - Control Manual sin librerías
const int IR_PIN = 9;

// Genera la portadora de 38kHz a mano para que no se bloquee el Timer
void oscilar(int microsegundos) {
  long ciclos = microsegundos / 26; 
  for (long i = 0; i < ciclos; i++) {
    digitalWrite(IR_PIN, HIGH);
    delayMicroseconds(9);  // Pulso ON
    digitalWrite(IR_PIN, LOW);
    delayMicroseconds(12); // Pulso OFF (ajustado para 38kHz)
  }
}

void setup() {
  pinMode(IR_PIN, OUTPUT);
  digitalWrite(IR_PIN, LOW);
  Serial.begin(115200);
  Serial.println("INICIANDO PARPADEO CONTINUO EN PIN 9...");
}

void loop() {
  Serial.println("Enviando ráfaga...");
  
  // Simulamos una ráfaga típica de AC para ver el parpadeo
  oscilar(4500);         // Header Mark
  delayMicroseconds(4400); // Header Space
  
  // Enviamos 32 bits de prueba
  for(int i=0; i<32; i++){
    oscilar(560);
    delayMicroseconds(560);
  }
  
  digitalWrite(IR_PIN, LOW); // SEGURIDAD: Forzamos apagado
  
  Serial.println("Pulso enviado. Esperando 2 segundos...");
  delay(2000); 
}
